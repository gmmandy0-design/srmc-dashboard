{
  "name": "SRMC Streamlit Dashboard",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "srmc_app.py"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "updateContentCommand": "pip install -r requirements.txt",

  "postAttachCommand": {
    "server": "streamlit run srmc_app.py --server.runOnSave true --server.enableCORS false --server.enableXsrfProtection false"
  },

  "portsAttributes": {
    "8501": {
      "label": "SRMC Dashboard",
      "onAutoForward": "openPreview"
    }
  },

  "forwardPorts": [8501]
}
